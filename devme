#!/usr/bin/env python3

import sys
from pathlib import Path


def main() -> None:
    repo_root = Path(__file__).resolve().parent
    src_path = repo_root / "src"
    if src_path.exists():
        sys.path.insert(0, str(src_path))

    from devme.cli import main as cli_main

    cli_main()


if __name__ == "__main__":
    main()
