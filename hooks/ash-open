#!/bin/bash
# ash-open — open a directory's companion file in the devme web viewer.
# Starts ash serve automatically if it's not already running.
# Designed as a Dolphin service menu action but works standalone.
#
# Install: copy to ~/.local/bin/ash-open and chmod +x
# Dolphin: see hooks/dolphin/ for .desktop service menu files
#
# Usage: ash-open [directory]   (defaults to $PWD)

DIR="${1:-$PWD}"
PORT="${ASH_PORT:-7272}"

# Resolve ash binary
ASH_BIN="${ASH_BIN:-}"
if [ -z "$ASH_BIN" ]; then
    ASH_BIN="$(command -v ash 2>/dev/null)"
fi

# Resolve companion filename from config (default: ash.md)
MD_FILE="ash.md"
CONFIG="$HOME/.ash/config.json"
if [ -f "$CONFIG" ] && command -v python3 &>/dev/null; then
    _fn=$(python3 -c "
import json, sys
try:
    d = json.load(open('$CONFIG'))
    print(d.get('filename', 'ash.md'))
except Exception:
    print('ash.md')
" 2>/dev/null)
    [ -n "$_fn" ] && MD_FILE="$_fn"
fi

# Fork immediately so Dolphin doesn't freeze
(
    # Start server if not already listening
    if ! (echo > /dev/tcp/localhost/$PORT) 2>/dev/null; then
        if [ -z "$ASH_BIN" ] || [ ! -x "$ASH_BIN" ]; then
            command -v notify-send &>/dev/null && \
                notify-send "devme" "ash not found — install it to \$PATH" --icon=dialog-error
            exit 1
        fi
        "$ASH_BIN" serve --port "$PORT" --no-browser &
        sleep 0.8
    fi
    xdg-open "http://localhost:${PORT}/view?path=${DIR}/${MD_FILE}"
) &
disown
