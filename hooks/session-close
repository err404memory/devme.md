#!/bin/bash
# session-close — triggered by the bash EXIT trap in ~/.bashrc.
# Looks for a recently-modified AI transcript and schedules async parsing.
# Silently exits if no recent AI session is found.
#
# Install: copy to ~/.local/bin/session-close and chmod +x
# Activate: add the following to ~/.bashrc (inside the interactive-shell guard):
#   trap '~/.local/bin/session-close' EXIT
#
# NOTE: Do NOT add an interactive-shell guard here ($- check).
# This script always runs as a non-interactive child process — $- never contains 'i'.
# The interactive check lives in ~/.bashrc: the trap is only registered there,
# and ~/.bashrc only runs for interactive shells.

CLAUDE_PROJECTS="$HOME/.claude/projects"
LOG="$HOME/.logs/session-parser.log"

# Configurable: seconds — transcripts modified within this window = this session
THRESHOLD="${ASH_SESSION_THRESHOLD:-300}"

# ── Guard: require parse-ai-session ──────────────────────────────────────────
PARSE_AI="$HOME/.local/bin/parse-ai-session"
if [ ! -x "$PARSE_AI" ]; then
    exit 0
fi

# ── Claude Code transcript ────────────────────────────────────────────────────
now=$(date +%s)
recent_file=""
recent_mtime=0

if [ -d "$CLAUDE_PROJECTS" ]; then
    while IFS= read -r f; do
        mtime=$(stat -c %Y "$f" 2>/dev/null) || continue
        age=$(( now - mtime ))
        if [ "$age" -lt "$THRESHOLD" ] && [ "$mtime" -gt "$recent_mtime" ]; then
            recent_file="$f"
            recent_mtime="$mtime"
        fi
    done < <(find "$CLAUDE_PROJECTS" -name "*.jsonl" 2>/dev/null)
fi

if [ -n "$recent_file" ]; then
    mkdir -p "$(dirname "$LOG")"
    nohup "$PARSE_AI" "$recent_file" "claude" >> "$LOG" 2>&1 &
    disown
fi

# ── Ghostty terminal log ──────────────────────────────────────────────────────
# GHOSTTY_LOG is exported by ~/.bashrc when a non-tmux Ghostty window starts
# logging via `script`. Parse the log if it's recent (< 1 hour old).
PARSE_GHOSTTY="$HOME/.local/bin/parse-ghostty-session"
if [ -x "$PARSE_GHOSTTY" ] && [ -n "$GHOSTTY_LOG" ] && [ -f "$GHOSTTY_LOG" ]; then
    ghost_mtime=$(stat -c %Y "$GHOSTTY_LOG" 2>/dev/null || echo 0)
    ghost_age=$(( now - ghost_mtime ))
    if [ "$ghost_age" -lt 3600 ]; then
        mkdir -p "$(dirname "$LOG")"
        nohup "$PARSE_GHOSTTY" "$GHOSTTY_LOG" >> "$LOG" 2>&1 &
        disown
    fi
fi

# ── Future tool support ───────────────────────────────────────────────────────
# Add similar blocks here for Kilo, Codex, etc.
# Find their transcript directories, use the same mtime pattern,
# and pass the tool name as the second argument to parse-ai-session.
#
# Example:
# KILO_SESSIONS="$HOME/.kilo/sessions"
# ... (same find + mtime loop, call: nohup "$PARSE_AI" "$recent_file" "kilo" ...)
